# ────────────────────────────────────────────────────────────
# petwelly-web · Variables de entorno
# Copia este archivo a `.env.local` y rellena los valores.
# Las variables prefijadas con NEXT_PUBLIC_ se exponen al cliente.
# ────────────────────────────────────────────────────────────

# URL canónica de producción (sin slash final). Se usa en sitemap, robots,
# canonical tags y JSON-LD. En desarrollo usa http://localhost:3000.
NEXT_PUBLIC_SITE_URL=https://www.petwelly.com

# URL del ERP (donde apuntan los CTAs «Entrar» y «Empezar gratis»).
NEXT_PUBLIC_APP_URL=https://app.petwellly.com

# Endpoint del backend para el formulario de contacto (POST JSON).
# Si está vacío, el formulario hará un mailto: como fallback.
NEXT_PUBLIC_CONTACT_ENDPOINT=

# WhatsApp comercial (formato internacional sin +, ej. 34600000000).
NEXT_PUBLIC_WHATSAPP=34600000000

# Google Search Console verification (opcional). Solo el token, sin la meta.
NEXT_PUBLIC_GSC_VERIFICATION=

# Plausible / analytics simple (opcional).
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
